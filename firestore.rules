rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // User Profiles: each user reads/writes only their own doc
    // =========================================================
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =========================================================
    // Leagues
    // =========================================================
    match /leagues/{leagueId} {

      // Public read — anyone can browse leagues
      allow read: if true;

      // Any authenticated user can create a new league
      allow create: if request.auth != null;

      // Updates require authentication AND league membership
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberUids;

      // Only the creator can delete the league
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;

      // =========================================================
      // Matches subcollection
      // =========================================================
      match /matches/{matchId} {
        // Anyone can read match data, only authenticated users can write
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null;
      }

      // =========================================================
      // Notifications subcollection (for future use)
      // =========================================================
      match /notifications/{notificationId} {
        allow read: if request.auth != null
                     && request.auth.uid == resource.data.targetUid;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null;
      }
    }
  }
}

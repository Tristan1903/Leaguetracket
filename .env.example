# VITE_SUPABASE_URL: The URL of your Supabase project.
# Found in Supabase Dashboard > Settings > API.
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: The anon/public API key for your Supabase project.
# Found in Supabase Dashboard > Settings > API.
VITE_SUPABASE_ANON_KEY="your-anon-key"

# GEMINI_API_KEY: Required for Gemini AI API calls (optional, AI Studio injects).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (optional, AI Studio injects).
APP_URL="MY_APP_URL"
